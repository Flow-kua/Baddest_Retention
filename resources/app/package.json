{
  "name": "baddest_retention",
  "version": "1.0.0",
  "description": "Baddest_Retention - 桌面知识宠物",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.baddest_retention.pet",
    "productName": "Baddest Retention",
    "files": [
      "main.js",
      "index.html",
      "chat.html",
      "renderer.js",
      "chat.js",
      "avatar*.png",
      "icon.png",
      "icon.ico",
      "inbox/**"
    ],
    "extraResources": [
      {
        "from": "../../backend/dist/backend.exe",
        "to": "backend.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Baddest Retention",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  },
  "keywords": [
    "electron",
    "baddest_retention"
  ],
  "author": "Baddest_Retention Team",
  "license": "MIT",
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
